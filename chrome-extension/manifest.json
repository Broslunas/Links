{
  "manifest_version": 3,
  "name": "Broslunas Links",
  "version": "1.0.0",
  "description": "Shorten URLs instantly with Broslunas Links.",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "https://brlns.es/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://brlns.es/extension/login", "http://localhost:3000/extension/login"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  }
}
